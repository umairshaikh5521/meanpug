---
export interface Props {
    shape: string;
}
const { shape } = Astro.props;

const colors = {
    cyan: '#5FE0D8',
    yellow: '#FCE487',
    blue: '#3F4DF4',
    orange: '#F28C36',
    red: '#E83D46'
};

let fill = colors.cyan;
let width = 24;
let height = 48;
let blocks = []; // [x, y]

switch (shape) {
    case 'seo':
        fill = colors.cyan;
        width = 24; height = 36;
        blocks = [[1,0], [1,1], [0,2], [1,2]];
        break;
    case 'branding':
        fill = colors.yellow;
        blocks = [[0,0], [0,1], [1,1], [1,2]];
        break;
    case 'web':
        fill = colors.cyan;
        width = 12; height = 48;
        blocks = [[0,0], [0,1], [0,2], [0,3]];
        break;
    case 'digital':
        fill = colors.blue;
        width = 24; height = 36;
        blocks = [[0,0], [0,1], [0,2], [1,2]];
        break;
    case 'ai':
        fill = colors.blue;
        width = 24; height = 36;
        blocks = [[0,0], [0,1], [1,1]]; 
        break;
    case 'social':
        fill = colors.orange;
        width = 24; height = 36;
        blocks = [[0,0], [0,1], [1,1], [0,2]];
        break;
    case 'content':
        fill = colors.cyan;
        width = 24; height = 36;
        blocks = [[1,0], [1,1], [0,2], [1,2]];
        break;
    case 'tv':
        fill = colors.red;
        width = 24; height = 36;
        blocks = [[0,0], [0,1], [1,1], [0,2]];
        break;
    case 'radio':
        fill = colors.yellow;
        width = 24; height = 36;
        blocks = [[0,0], [0,1], [1,1], [0,2]];
        break;
    case 'ooh':
        fill = colors.cyan;
        width = 24; height = 36;
        blocks = [[1,0], [1,1], [0,2], [1,2]];
        break;
    case 'email':
        fill = colors.yellow;
        width = 24; height = 36;
        blocks = [[0,0], [0,1], [1,1], [1,2]];
        break;
    case 'video':
        fill = colors.cyan;
        width = 12; height = 48;
        blocks = [[0,0], [0,1], [0,2], [0,3]];
        break;
    default:
        fill = colors.cyan;
        blocks = [[0,0]];
}
---
<svg width={width} height={height} viewBox={`0 0 ${width} ${height}`} class="overflow-visible block">
    {blocks.map(([x, y]) => (
        <rect x={x * 12} y={y * 12} width="12" height="12" fill={fill} stroke="#1E3A8A" stroke-width="1.5" />
    ))}
</svg>
