---
import { Image } from "astro:assets";
---

<section class="pt-12 pb-16 bg-purple text-center mp-mobile-bounds md:px-0">
    <Image
        width="20"
        height="18"
        decoding="async"
        src="/assets/images/icons/ic-paw-yellow.svg"
        class="mx-auto w-8 md:w-12 delay-500"
        data-inviewport="compress-out"
        alt="Paw icon"
    />

    <h2
        class="mp-header mp-header--4xl md:mp-header--7xl lg:mp-header--8xl text-yellow font-bold pt-4 pb-2"
    >
        <span class="ez-toc-section" id="6-billion"></span>$6 billion+<span
            class="ez-toc-section-end"></span>
    </h2>

    <p
        class="text-white leading-relaxed text-2xl md:text-3xl w-full md:w-3/4 lg:w-1/2 xl:w-1/3 mx-auto"
    >
        in case recoveries have been won by firms we advertise for.
    </p>

    <div class="pt-8">
        <a
            href="https://www.meanpug.com/contact-us/"
            class="mp-cta-button mp-cta-button--secondary"
        >
            Contact a Pug
        </a>
    </div>
</section>

