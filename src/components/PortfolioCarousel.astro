---
import { Image } from "astro:assets";
---

<section
    class="pt-8 pb-8 md:pb-16 bg-yellow overflow-hidden mp-portfolio-carousel"
>
    <div class="container mx-auto border-t border-purple">
        <div class="pt-4 md:pt-12">
            <h3
                class="mp-mobile-bounds mp-header mp-header--5xl md:mp-header--6xl font-bold text-purple"
            >
                <span class="ez-toc-section" id="our-portfolio"></span>Our
                Portfolio<span class="ez-toc-section-end"></span>
            </h3>

            <div class="flex flex-col md:flex-row pt-6 md:pt-12 pb-8 md:pb-16">
                <div class="w-full md:w-1/3 shrink-0 mp-mobile-bounds">
                    <p class="text-3xl md:text-4xl text-purple pl-8">
                        We can be mean and still make you happy
                    </p>

                    <div class="hidden md:block pt-12 md:pt-32">
                        <a
                            href="/portfolio/"
                            class="mp-cta-button mp-cta-button--primary"
                        >
                            Full Portfolio
                        </a>
                    </div>
                </div>

                <div class="w-full md:w-2/3 pt-8 md:pt-0">
                    <div
                        class="mp-carousel glide relative mp-js-cursor-container"
                        id="mp-portfolio-carousel"
                        data-cursor-image="/assets/images/illustrations/ill-drag-paw-dark.png"
                    >
                        <div class="glide__track" data-glide-el="track">
                            <ul class="glide__slides">
                                <li class="glide__slide">
                                    <a
                                        href="https://www.meanpug.com/portfolio/pond-lehocky-giordano-llp/"
                                    >
                                        <Image
                                            src={"/assets/images/portfolio/Pond-thumb-1024x731.png"}
                                            width={1024}
                                            height={731}
                                            loading="lazy"
                                            decoding="async"
                                            sizes="(min-width: 768px) 66vw, 100vw"
                                            alt="Pond Lehocky Giordano LLP"
                                            class="w-full"
                                        />
                                    </a>
                                </li>
                                <li class="glide__slide">
                                    <a
                                        href="https://www.meanpug.com/portfolio/hawklaw/"
                                    >
                                        <Image
                                            src={"/assets/images/portfolio/HawkLaw-thumb-1024x731.png"}
                                            width={1024}
                                            height={731}
                                            loading="lazy"
                                            decoding="async"
                                            sizes="(min-width: 768px) 66vw, 100vw"
                                            alt="HawkLaw"
                                            class="w-full"
                                        />
                                    </a>
                                </li>
                                <li class="glide__slide">
                                    <a
                                        href="https://www.meanpug.com/portfolio/pinkham-associates-aplc/"
                                    >
                                        <Image
                                            src={"/assets/images/portfolio/Pinkham-thumb-1024x731.png"}
                                            width={1024}
                                            height={731}
                                            loading="lazy"
                                            decoding="async"
                                            sizes="(min-width: 768px) 66vw, 100vw"
                                            alt="Pinkham & Associates, APLC"
                                            class="w-full"
                                        />
                                    </a>
                                </li>
                                <li class="glide__slide">
                                    <a
                                        href="https://www.meanpug.com/portfolio/wallace-law/"
                                    >
                                        <Image
                                            src={"/assets/images/portfolio/wallace-1024x731.png"}
                                            width={1024}
                                            height={731}
                                            loading="lazy"
                                            decoding="async"
                                            sizes="(min-width: 768px) 66vw, 100vw"
                                            alt="Wallace Law"
                                            class="w-full"
                                        />
                                    </a>
                                </li>
                                <li class="glide__slide">
                                    <a
                                        href="https://www.meanpug.com/portfolio/burner-prudenti-law/"
                                    >
                                        <Image
                                            src={"/assets/images/portfolio/Burner-Prudenti-thumb-1024x731.png"}
                                            width={1024}
                                            height={731}
                                            loading="lazy"
                                            decoding="async"
                                            sizes="(min-width: 768px) 66vw, 100vw"
                                            alt="Burner Prudenti Law"
                                            class="w-full"
                                        />
                                    </a>
                                </li>
                                <li class="glide__slide">
                                    <a
                                        href="https://www.meanpug.com/portfolio/pitta-baione-llp/"
                                    >
                                        <Image
                                            src={"/assets/images/portfolio/Pitta-thumb-1024x731.png"}
                                            width={1024}
                                            height={731}
                                            loading="lazy"
                                            decoding="async"
                                            sizes="(min-width: 768px) 66vw, 100vw"
                                            alt="Pitta & Baione LLP"
                                            class="w-full"
                                        />
                                    </a>
                                </li>
                                <li class="glide__slide">
                                    <a
                                        href="https://www.meanpug.com/portfolio/the-fried-firm/"
                                    >
                                        <Image
                                            src={"/assets/images/portfolio/Fried-thumb-1024x731.png"}
                                            width={1024}
                                            height={731}
                                            loading="lazy"
                                            decoding="async"
                                            sizes="(min-width: 768px) 66vw, 100vw"
                                            alt="The Fried Firm"
                                            class="w-full"
                                        />
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <div class="block md:hidden text-center py-4">
                <a
                    href="/portfolio/"
                    class="mp-cta-button mp-cta-button--primary"
                >
                    Full Portfolio
                </a>
            </div>
        </div>
    </div>
</section>

<style>
    .mp-portfolio-carousel .mp-cursor--js {
        z-index: 30;
    }
</style>
