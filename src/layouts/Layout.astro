---
import "../styles/global.css";
import NoticeModal from "../components/NoticeModal.astro";

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
}

const {
	title = "MeanPug | Award-Winning Digital Agency",
	description = "MeanPug is a full-service digital agencyfor Law Firms.",
	ogImage = "/og-image.png",
} = Astro.props;

const siteBase = Astro.site ?? Astro.url;
const pageUrl = new URL(Astro.url.pathname, siteBase).toString();
const ogImageUrl = new URL(ogImage, siteBase).toString();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
		<link
			rel="apple-touch-icon"
			href="/assets/images/favicons/cropped-meanpug-300x300.png"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={pageUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="MeanPug" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={pageUrl} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:secure_url" content={ogImageUrl} />
		<meta property="og:image:type" content="image/png" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	</head>
	<body
		class="home wp-singular page-template-default page page-id-66 wp-custom-logo wp-theme-meanpug-theme-v2"
	>
		<div id="page" class="site">
			<slot />
		</div>

		<script src="/assets/js/jquery.min.js" is:inline></script>
		<script src="/assets/js/jquery-migrate.min.js" is:inline defer></script>
		<script src="/assets/js/main.js" is:inline defer></script>
		<NoticeModal />
		<script is:inline>
			(function () {
				const STORAGE_KEY = 'mp_last_visit_notify';
				const ONE_WEEK = 7 * 24 * 60 * 60 * 1000;
				const now = Date.now();
				const last = localStorage.getItem(STORAGE_KEY);

				if (!last || now - parseInt(last, 10) > ONE_WEEK) {
					fetch('/api/notify', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ page: window.location.pathname + window.location.search }),
					})
						.then(function (res) {
							if (res.ok) localStorage.setItem(STORAGE_KEY, String(now));
						})
						.catch(function () {});
				}
			})();
		</script>
	</body>
</html>
