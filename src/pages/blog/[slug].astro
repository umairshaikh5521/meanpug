---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getAllPostSlugs, getPostBySlug, getPosts, formatDate, getFeaturedImageUrl, stripHtml } from "../../lib/wordpress";

export async function getStaticPaths() {
    const slugs = await getAllPostSlugs();
    return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post = await getPostBySlug(slug);

if (!post) {
    return Astro.redirect("/blog/");
}

const image = getFeaturedImageUrl(post, "full");
const imageAlt = post._embedded?.["wp:featuredmedia"]?.[0]?.alt_text || stripHtml(post.title.rendered);
const author = post._embedded?.author?.[0];
const categories = (post._embedded?.["wp:term"] ?? []).flat().filter((t) => t.name !== "Uncategorized");
const tags = post._embedded?.["wp:term"]?.[1] ?? [];
const allTerms = [...categories, ...tags];
const plainExcerpt = stripHtml(post.excerpt.rendered).slice(0, 300);
const postDate = formatDate(post.date);

// Fetch popular / recent posts for sidebar carousel (exclude current post)
const recentPosts = (await getPosts({ perPage: 4 })).filter((p) => p.slug !== slug).slice(0, 3);
---

<Layout
    title={`${stripHtml(post.title.rendered)} | MeanPug Blog`}
    description={plainExcerpt.slice(0, 160)}
    ogImage={image ?? "/og-image.avif"}
>
    <Header />

    <main id="main" class="site-main bg-yellow">
        <header class="container mx-auto md:pt-8">
            <!-- Featured Image -->
            {image && (
                <div class="overflow-hidden">
                    <img
                        width="2560"
                        height="960"
                        alt={imageAlt}
                        fetchpriority="high"
                        src={image}
                        class="w-full mp-post-header-image max-h-[40rem] object-cover object-center wp-post-image"
                        decoding="async"
                    />
                </div>
            )}

            <!-- Breadcrumbs -->
            <div class="pt-4 md:pt-8 pb-4 md:pb-0 mp-breadcrumbs mp-mobile-bounds">
                <p id="breadcrumbs">
                    <span>
                        <span><a href="/">Home</a></span>
                        &gt;
                        <span><a href="/blog/">Drawing Board</a></span>
                        &gt;
                        <span class="breadcrumb_last" aria-current="page">
                            <strong set:html={post.title.rendered} />
                        </span>
                    </span>
                </p>
            </div>

            <!-- Title / Excerpt / Author hero section -->
            <div class="border-t-3 border-b-3 border-purple py-6 md:my-6 md:flex mp-mobile-bounds">
                <div class="md:w-1/3">
                    <h1 class="text-purple mp-header--3xl font-bold" set:html={post.title.rendered} />
                    {allTerms.length > 0 && (
                        <ul class="pt-2 md:pt-8 flex flex-wrap">
                            {allTerms.slice(0, 5).map((term) => (
                                <li class="pr-4 text-sm text-purple underline font-bold">
                                    {term.name}
                                </li>
                            ))}
                        </ul>
                    )}
                </div>
                <div class="md:w-2/3 md:px-16">
                    <div class="text-purple-900 py-3 md:py-0">
                        <p>{plainExcerpt}</p>
                    </div>
                    <div class="flex justify-between items-center text-sm text-purple pt-12">
                        {author && (
                            <a href={`/team/`}>
                                <strong>by {author.name}</strong>
                            </a>
                        )}
                        <strong>{postDate}</strong>
                    </div>
                </div>
            </div>
        </header>

        <!-- Content + Sidebar -->
        <div class="flex flex-col md:flex-row container mx-auto py-6 md:py-12">
            <!-- Sidebar -->
            <aside class="w-full md:w-1/3 xl:w-1/4 pr-0 md:pr-6 xl:pr-12 order-last md:order-first">
                <aside id="secondary" class="widget-area">
                    <!-- Marketing Services CTA Widget -->
                    <section class="widget widget_mp_page_link_widget">
                        <div class="pl-4 lg:pl-8 pr-3 lg:pr-12 py-8 bg-purple relative">
                            <video
                                class="absolute left-0 top-0 w-full h-full z-0 object-cover object-center"
                                autoplay
                                loop
                                muted
                                playsinline
                            >
                                <source
                                    src="https://media-v2.meanpug.com/wp-content/uploads/2021/09/Integration-Matters-Tetris-Video-1.mp4"
                                    type="video/mp4"
                                />
                                Your browser does not support the video tag.
                            </video>
                            <div class="relative z-10">
                                <h2 class="text-purple-900 font-bold text-xl">Our Marketing Services</h2>
                                <hr class="w-16 my-3 border-2 border-purple-900" />
                                <div>
                                    <div class="mp-header mp-header--xl text-purple-900">
                                        <p>All Marketing Solutions Under One Roof</p>
                                    </div>
                                    <div class="flex items-center justify-between pt-4">
                                        <a href="/what-we-offer/" class="mp-play-button">
                                            <span>Play</span>
                                        </a>
                                        <a
                                            class="flex items-center font-bold text-sm text-purple-900 hover:text-purple transition-transform transform hover:scale-110 mp-link mp-link--ic hover:mp-link--ic--purple"
                                            href="/contact-us/"
                                        >
                                            <img
                                                alt="plus icon"
                                                src="/assets/images/icons/ic-plus-circle-purple-900.svg"
                                                class="mp-link--ic__ic"
                                            />
                                            <span class="ml-2 md:ml-4 inline-block underline pt-1">
                                                Chat Now
                                            </span>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Popular Posts Carousel Widget -->
                    {recentPosts.length > 0 && (
                        <section id="mp_post_carousel_widget-2" class="widget widget_mp_post_carousel_widget">
                            <div class="pt-8 pb-4 lg:pb-0 overflow-hidden" id="mp-post-carousel-widget">
                                <div class="flex justify-between items-center px-2 md:px-0">
                                    <h2 class="text-xl font-bold text-purple-900">Popular Posts</h2>
                                    <div class="flex items-center">
                                        <img
                                            alt="Left Caret Icon"
                                            src="/assets/images/icons/ic-caret-left-purple-dark.svg"
                                            class="h-3 cursor-pointer mp-carousel-btn--prev"
                                        />
                                        <img
                                            alt="Right Caret Icon"
                                            src="/assets/images/icons/ic-caret-right-purple-dark.svg"
                                            class="h-3 ml-6 cursor-pointer mp-carousel-btn--next"
                                        />
                                    </div>
                                </div>
                                <div class="pt-2">
                                    <div id="mp-post-carousel-widget-carousel" class="glide">
                                        <div class="glide__track" data-glide-el="track">
                                            <ul class="glide__slides">
                                                {recentPosts.map((rPost) => {
                                                    const rImage = getFeaturedImageUrl(rPost, "medium") || "/assets/images/logos/MeanPug-Logo.avif";
                                                    const rAlt = rPost._embedded?.["wp:featuredmedia"]?.[0]?.alt_text || stripHtml(rPost.title.rendered);
                                                    return (
                                                        <li class="glide__slide">
                                                            <div class="mp-service">
                                                                <img
                                                                    width="300"
                                                                    height="113"
                                                                    alt={rAlt}
                                                                    src={rImage}
                                                                    class="w-full wp-post-image"
                                                                    loading="lazy"
                                                                    decoding="async"
                                                                />
                                                                <a href={`/blog/${rPost.slug}/`}>
                                                                    <strong class="pt-2 block text-lg text-purple px-2 md:px-0" set:html={rPost.title.rendered} />
                                                                </a>
                                                                <div class="pt-2 md:pt-4 px-2 md:px-0">
                                                                    <a
                                                                        href={`/blog/${rPost.slug}/`}
                                                                        class="text-purple-900 hover:text-purple mp-link mp-link--caret flex items-center justify-end text-xs font-bold"
                                                                        title={stripHtml(rPost.title.rendered)}
                                                                    >
                                                                        <span class="underline">Read More</span>
                                                                        <img
                                                                            alt="right caret icon"
                                                                            src="/assets/images/icons/ic-caret-right-yellow.svg"
                                                                            class="mp-link--caret__ic ml-2"
                                                                        />
                                                                    </a>
                                                                </div>
                                                            </div>
                                                        </li>
                                                    );
                                                })}
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
                    )}

                    <!-- Useful Resources / Download Widget -->
                    <section class="widget widget_mp_download_widget">
                        <div class="pb-3 md:pb-8 md:pt-2">
                            <div class="bg-purple px-4 lg:px-8 py-6 lg:py-8">
                                <h2 class="text-yellow font-bold text-xl">Useful Resources</h2>
                                <hr class="w-16 border-2 border-yellow my-4" />
                                <div class="text-white text-xl">
                                    <h3>
                                        <strong>How to Pick A New Marketing Partner</strong>
                                    </h3>
                                </div>
                            </div>
                            <div>
                                <a
                                    href="https://media-v2.meanpug.com/wp-content/uploads/2022/11/Choosing-a-New-Law-Firm-Marketing-Vendor.pdf"
                                    class="mp-cursor mp-cursor-paw--download-paw-dark overflow-hidden block max-h-48"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    <img
                                        width="300"
                                        height="200"
                                        alt="designed purple PDF of MeanPug marketing vendor checklist on yellow background"
                                        src="https://media-v2.meanpug.com/wp-content/uploads/2022/11/choosing-a-marketing-vendor-cover-image-300x200.avif"
                                        class="w-full mp-animation mp-animation--scale-hover mp-animation--scale-hover--110 wp-post-image"
                                        loading="lazy"
                                        decoding="async"
                                    />
                                </a>
                            </div>
                        </div>
                    </section>

                    <!-- Social Share Widget -->
                    <section class="mp-last-widget-sticky sticky top-32 widget widget_mp_social_share_widget">
                        <div class="py-3 md:py-8 px-4 md:px-0">
                            <strong class="text-purple-900">Share This Post</strong>
                            <ul class="flex items-center pt-4">
                                <li>
                                    <button
                                        class="mp-link mp-link--circle-expand mp-share-button relative"
                                        data-target="facebook"
                                        aria-label="Share on Facebook"
                                    >
                                        <img
                                            alt="Facebook Follow Icon"
                                            src="/assets/images/icons/ic-fb.svg"
                                            class="h-8 relative z-10"
                                        />
                                    </button>
                                </li>
                                <li class="px-8">
                                    <button
                                        data-target="linkedin"
                                        class="mp-link mp-link--circle-expand mp-share-button relative"
                                        aria-label="Share on LinkedIn"
                                    >
                                        <img
                                            alt="LinkedIn Follow Icon"
                                            src="/assets/images/icons/ic-linkedin.svg"
                                            class="h-8 relative z-10"
                                        />
                                    </button>
                                </li>
                                <li>
                                    <a
                                        class="mp-link mp-link--circle-expand relative block"
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        href="https://www.instagram.com/meanpugdigital/"
                                        aria-label="Follow on Instagram"
                                    >
                                        <img
                                            alt="Instagram Follow Icon"
                                            src="/assets/images/icons/ic-ig.svg"
                                            class="h-6 relative z-10"
                                        />
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </section>
                </aside>
            </aside>

            <!-- Main Content -->
            <div class="w-full md:w-2/3 xl:w-3/4 md:pl-8 order-first md:order-last mp-mobile-bounds overflow-hidden">
                <article
                    id={`post-${post.id}`}
                    class="mp-core-style mp-content-style"
                    set:html={post.content.rendered}
                />
            </div>
        </div>
    </main>

    <Footer />
</Layout>

<script>
    // Social share buttons
    document.querySelectorAll('.mp-share-button').forEach((btn) => {
        btn.addEventListener('click', () => {
            const target = btn.getAttribute('data-target');
            const url = encodeURIComponent(window.location.href);
            const title = encodeURIComponent(document.title);
            let shareUrl = '';

            if (target === 'facebook') {
                shareUrl = `https://www.facebook.com/sharer/sharer.php?u=${url}`;
            } else if (target === 'linkedin') {
                shareUrl = `https://www.linkedin.com/shareArticle?mini=true&url=${url}&title=${title}`;
            }

            if (shareUrl) {
                window.open(shareUrl, '_blank', 'width=600,height=400');
            }
        });
    });
</script>
