---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/common/Header.astro";
import Footer from "../../components/common/Footer.astro";
import {
    getAllPosts,
    formatDate,
    getFeaturedImageUrl,
    stripHtml,
} from "../../lib/wordpress";
import type { WPPost } from "../../lib/wordpress";
import type { Page } from "astro";

export async function getStaticPaths({ paginate }) {
    const rawPosts = await getAllPosts();
    console.log(rawPosts);

    // Move sticky (featured) posts to the front
    const sortedPosts = [...rawPosts].sort(
        (a, b) => (b.sticky ? 1 : 0) - (a.sticky ? 1 : 0),
    );
    return paginate(sortedPosts, { pageSize: 8 });
}

interface Props {
    page: Page<WPPost>;
    post?: WPPost;
    featuredPosts?: WPPost[];
}

const { page } = Astro.props;
const posts = page.data;
---

<Layout
    title="Law Firm Marketing Blog | MeanPug"
    description="Expert law firm marketing insights, tips, and strategies from the MeanPug team."
>
    <Header />

    <main id="main" class="site-main bg-yellow overflow-hidden">
        <div id="primary" class="content-area bg-yellow">
            <header class="pt-8 md:pt-16 pb-8 lazyloaded">
                <div class="container mx-auto relative">
                    <div
                        class="mp-header mp-header--5xl md:mp-header--6xl lg:mp-header--7xl text-purple-900 mp-emphasis-text mp-emphasis-text--bg-purple mp-emphasis-text--text-yellow font-bold relative z-10"
                    >
                        <h1>Our <strong>Legal Marketing</strong><br /> Blog</h1>
                    </div>
                    <span class="mp-header text-xl font-bold italic"
                        >(Built on Astro)</span
                    >

                    <div
                        class="svg-animation absolute bottom-0 left-0 lg:left-1/2 h-32 md:h-64 ml-24 md:ml-16 md:ml-0 -mb-8 md:-mb-24 z-0"
                        data-svg="/assets/animations/shapes/squiggle-yellow-light/squiggle-yellow-light.json"
                    >
                    </div>
                    <div
                        class="svg-animation absolute top-0 right-0 h-16 md:h-32 mt-8 md:mt-24 mr-8 md:mr-24 z-0"
                        data-svg="/assets/animations/shapes/spring-purple-900/spring-purple-900.json"
                    >
                    </div>
                </div>
            </header>
        </div>

        <div class="container mx-auto pb-16 px-0 relative z-10">
            {
                posts.length === 0 ? (
                    <p class="text-center text-purple-900 py-16">
                        No posts found. Make sure WordPress is running and the
                        API URL is correct.
                    </p>
                ) : (
                    <div class="grid grid-cols-1 md:grid-cols-2 md:gap-y-12 md:gap-x-8">
                        {posts.map((post, index) => {
                            const isFeatured = post.sticky || index === 0;
                            const image =
                                getFeaturedImageUrl(
                                    post,
                                    isFeatured ? "full" : "medium_large",
                                ) || "/assets/images/logos/MeanPug-Logo.avif";
                            const excerpt =
                                stripHtml(post.excerpt.rendered).slice(0, 150) +
                                "…";
                            // Get all terms (categories & tags), filter out the default 'Uncategorized'
                            const categories = (
                                post._embedded?.["wp:term"] ?? []
                            )
                                .flat()
                                .filter((t) => t.name !== "Uncategorized");

                            if (isFeatured) {
                                return (
                                    <div class="md:col-span-2">
                                        <article class="md:py-8 relative">
                                            <div class="md:max-h-96 overflow-hidden">
                                                <a
                                                    href={`/blog/${post.slug}/`}
                                                    class="block mp-animation mp-animation--scale-hover mp-animation--scale-hover--125 mp-cursor-paw mp-cursor-paw--read-more-purple"
                                                >
                                                    <img
                                                        src={image}
                                                        alt={
                                                            post.title.rendered
                                                        }
                                                        class="w-full wp-post-image lazyloaded"
                                                        loading="lazy"
                                                        decoding="async"
                                                    />
                                                </a>
                                            </div>
                                            <div
                                                class="svg-animation absolute right-0 top-0 h-32 md:h-48 mt-12 md:mt-48 -mr-16 md:-mr-32 z-0"
                                                data-svg="/assets/animations/shapes/oval-360-blue/oval-360-blue.json"
                                            />
                                            <div class="border-t-3 border-b-3 border-purple py-6 my-6 md:flex container mx-auto mp-mobile-bounds">
                                                <div class="md:w-1/3">
                                                    <h2 class="text-purple mp-header--2xl md:mp-header--3xl font-bold">
                                                        <a
                                                            href={`/blog/${post.slug}/`}
                                                            class="mp-link mp-link--wavy"
                                                            set:html={
                                                                post.title
                                                                    .rendered
                                                            }
                                                        />
                                                    </h2>
                                                    {categories.length > 0 && (
                                                        <ul class="pt-2 md:pt-8 flex flex-wrap">
                                                            {categories
                                                                .slice(0, 5)
                                                                .map((cat) => (
                                                                    <li class="pr-4 text-sm text-purple underline font-bold">
                                                                        {
                                                                            cat.name
                                                                        }
                                                                    </li>
                                                                ))}
                                                        </ul>
                                                    )}
                                                </div>
                                                <div class="md:w-2/3 md:flex items-center justify-between">
                                                    <div class="text-purple-900 md:px-16 lg:px-32 py-3 md:py-0">
                                                        <p>{excerpt}</p>
                                                    </div>
                                                    <a
                                                        href={`/blog/${post.slug}/`}
                                                        class="mp-link mp-link--caret text-purple hover:text-purple-900 font-bold text-sm block flex-shrink-0"
                                                    >
                                                        <span class="underline">
                                                            Read More
                                                        </span>
                                                        <img
                                                            src="https://www.meanpug.com/wp-content/themes/meanpug-theme-v2/assets/images/icons/ic-caret-right-purple.svg"
                                                            class="w-2 inline-block mp-link--caret__ic lazyloaded"
                                                            alt="Caret Right"
                                                        />
                                                    </a>
                                                </div>
                                            </div>
                                        </article>
                                    </div>
                                );
                            }

                            return (
                                <article class="md:px-2 xl:px-0 py-2 md:py-0">
                                    <div class="md:max-h-96 overflow-hidden relative">
                                        <a
                                            href={`/blog/${post.slug}/`}
                                            class="block mp-animation mp-animation--scale-hover mp-animation--scale-hover--110 mp-cursor mp-cursor-paw--read-more-purple overflow-hidden"
                                        >
                                            <img
                                                src={image}
                                                alt={post.title.rendered}
                                                class="w-full h-[300px] object-cover object-center rounded-2xl wp-post-image lazyloaded"
                                                loading="lazy"
                                                decoding="async"
                                            />
                                        </a>
                                    </div>
                                    <div class="pt-4 mp-mobile-bounds">
                                        <h4 class="text-purple-900 font-bold mp-header mp-header--2xl md:h-32">
                                            <a
                                                href={`/blog/${post.slug}/`}
                                                class="mp-link mp-link--wavy"
                                                set:html={post.title.rendered}
                                            />
                                        </h4>
                                        <div class="text-sm text-purple-900 md:h-32 overflow-auto border-b-3 border-purple py-4 md:py-0">
                                            <p>{excerpt}</p>
                                        </div>
                                        <div class="flex justify-between items-center pt-4">
                                            {categories.length > 0 && (
                                                <ul class="flex flex-wrap">
                                                    {categories
                                                        .slice(0, 5)
                                                        .map((cat) => (
                                                            <li class="pr-4 text-sm text-purple font-bold">
                                                                {cat.name}
                                                            </li>
                                                        ))}
                                                </ul>
                                            )}
                                            <a
                                                href={`/blog/${post.slug}/`}
                                                class="mp-link mp-link--caret text-purple hover:text-purple-900 font-bold text-sm block flex-shrink-0"
                                            >
                                                <span class="underline">
                                                    Read More
                                                </span>
                                                <img
                                                    src="https://www.meanpug.com/wp-content/themes/meanpug-theme-v2/assets/images/icons/ic-caret-right-purple.svg"
                                                    class="w-2 inline-block mp-link--caret__ic lazyloaded"
                                                    alt="Caret Right"
                                                />
                                            </a>
                                        </div>
                                    </div>
                                </article>
                            );
                        })}
                    </div>
                )
            }

            <div class="block md:hidden pt-6">
                <div class="mp-pagination flex justify-center">
                    <nav
                        class="navigation pagination"
                        aria-label="Posts pagination"
                    >
                        <div class="nav-links">
                            {
                                page.url.prev && (
                                    <a
                                        class="prev page-numbers"
                                        href={page.url.prev}
                                    >
                                        Prev
                                    </a>
                                )
                            }
                            {
                                Array.from(
                                    { length: page.lastPage },
                                    (_, i) => i + 1,
                                ).map((pageNum) =>
                                    pageNum === page.currentPage ? (
                                        <span
                                            aria-current="page"
                                            class="page-numbers current"
                                        >
                                            {pageNum}
                                        </span>
                                    ) : (
                                        <a
                                            class="page-numbers"
                                            href={
                                                pageNum === 1
                                                    ? "/blog/"
                                                    : `/blog/${pageNum}/`
                                            }
                                        >
                                            {pageNum}
                                        </a>
                                    ),
                                )
                            }
                            {
                                page.url.next && (
                                    <a
                                        class="next page-numbers"
                                        href={page.url.next}
                                    >
                                        Next
                                    </a>
                                )
                            }
                        </div>
                    </nav>
                </div>
            </div>
            <div class="flex items-center justify-between pt-6 md:pt-16">
                <div class="w-1/2 md:w-1/3 lg:w-1/4">
                    {
                        page.url.prev && (
                            <a
                                class="bg-purple-900 hover:bg-purple text-yellow flex justify-between py-6 md:py-8 pl-4 pr-8 md:pr-16 w-full"
                                href={page.url.prev}
                            >
                                <img
                                    alt="left icon"
                                    src="https://www.meanpug.com/wp-content/themes/meanpug-theme-v2/assets/images/icons/ic-chevron-right-gold.svg"
                                    class="w-auto lazyloaded"
                                    style="transform: scaleX(-1);"
                                />
                                <span>Previous</span>
                            </a>
                        )
                    }
                </div>
                <div class="mp-pagination hidden md:block">
                    <nav
                        class="navigation pagination"
                        aria-label="Posts pagination"
                    >
                        <div class="nav-links">
                            {
                                Array.from(
                                    { length: page.lastPage },
                                    (_, i) => i + 1,
                                ).map((pageNum) =>
                                    pageNum === page.currentPage ? (
                                        <span
                                            aria-current="page"
                                            class="page-numbers current"
                                        >
                                            {pageNum}
                                        </span>
                                    ) : (
                                        <a
                                            class="page-numbers"
                                            href={
                                                pageNum === 1
                                                    ? "/blog/"
                                                    : `/blog/${pageNum}/`
                                            }
                                        >
                                            {pageNum}
                                        </a>
                                    ),
                                )
                            }
                        </div>
                    </nav>
                </div>
                <div class="w-1/2 md:w-1/3 lg:w-1/4 flex justify-end">
                    {
                        page.url.next && (
                            <a
                                class="bg-purple-900 hover:bg-purple text-yellow flex justify-between py-6 md:py-8 pl-8 md:pl-16 pr-4 w-full"
                                href={page.url.next}
                            >
                                <span>Next</span>
                                <img
                                    alt="right icon"
                                    src="https://www.meanpug.com/wp-content/themes/meanpug-theme-v2/assets/images/icons/ic-chevron-right-gold.svg"
                                    class="w-auto lazyloaded"
                                />
                            </a>
                        )
                    }
                </div>
            </div>
        </div>
    </main>

    <Footer />
</Layout>
